{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User profile information and verification status",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID" },
        "email": { "type": "string", "format": "email", "description": "User email address" },
        "displayName": { "type": "string", "description": "User display name" },
        "targetHighSchool": { "type": "string", "description": "Target high school" },
        "dailyGoal": { "type": "number", "description": "Daily question goal" },
        "isPremium": { "type": "boolean", "description": "Premium status" },
        "premiumExpiry": { "type": "string", "format": "date-time", "description": "Premium subscription expiration date" },
        "planName": { "type": "string", "description": "Name of the current subscription plan" },
        "isEmailVerified": { "type": "boolean", "description": "Email verification status" },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "User role" },
        "verificationCode": { "type": "string", "description": "6-digit verification code" },
        "verificationCodeExpires": { "type": "string", "format": "date-time", "description": "Verification code expiration" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Profile creation timestamp" }
      },
      "required": ["uid", "email", "displayName", "isEmailVerified", "createdAt"]
    },
    "PaymentNotification": {
      "title": "Payment Notification",
      "description": "Manual payment notification for IBAN transfers",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "User ID who made the payment" },
        "userEmail": { "type": "string", "format": "email", "description": "User email" },
        "senderName": { "type": "string", "description": "Name of the person who sent the money" },
        "paymentDate": { "type": "string", "format": "date", "description": "Date of payment" },
        "amount": { "type": "string", "description": "Amount paid" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"], "description": "Status of the notification" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Notification creation timestamp" }
      },
      "required": ["userId", "userEmail", "senderName", "paymentDate", "amount", "status", "createdAt"]
    },
    "Feedback": {
      "title": "Feedback",
      "description": "User feedback and suggestions",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "User ID who sent the feedback" },
        "userEmail": { "type": "string", "format": "email", "description": "User email" },
        "userName": { "type": "string", "description": "User display name" },
        "message": { "type": "string", "description": "Feedback message" },
        "reply": { "type": "string", "description": "Admin reply" },
        "status": { "type": "string", "enum": ["pending", "replied"], "description": "Status of the feedback" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Feedback creation timestamp" },
        "repliedAt": { "type": "string", "format": "date-time", "description": "Reply timestamp" }
      },
      "required": ["userId", "userEmail", "userName", "message", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles"
    },
    "/payment_notifications/{notificationId}": {
      "schema": "PaymentNotification",
      "description": "Manual payment notifications"
    },
    "/feedbacks/{feedbackId}": {
      "schema": "Feedback",
      "description": "User feedback and suggestions"
    }
  }
}
